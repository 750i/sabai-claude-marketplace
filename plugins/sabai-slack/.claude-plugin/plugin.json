{
  "name": "sabai-slack",
  "description": "Full-featured Slack integration for messaging, channels, and search",
  "version": "1.0.0",
  "author": "Sabai System",
  "keywords": ["slack", "messaging", "communication", "channels", "teams"],
  "mcpServers": {
    "slack": {
      "command": "npx",
      "args": ["-y", "slack-mcp-server@latest", "--transport", "stdio"],
      "env": {
        "SLACK_MCP_XOXP_TOKEN": "${SLACK_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true"
      }
    }
  },
  "skills": "./skills/",
  "commands": "./commands/"
}
